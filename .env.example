# Home Hub Configuration
# Copy this to .env and fill in your values
APP_ENV=development
LOCAL_IP=192.168.1.XXX        # Your PC's LAN IP (Sonos fetches TTS audio from here)

# SvelteKit static build directory, relative to project root.
FRONTEND_BUILD=frontend-svelte/build

# Hue Bridge
HUE_BRIDGE_IP=192.168.1.50
HUE_USERNAME=your-hue-bridge-username

# Sonos (auto-discovered by default, uncomment to override)
# SONOS_IP=192.168.1.XX

# TTS
TTS_VOICE=en-US-GuyNeural
TTS_VOLUME=80

# Logging
LOG_LEVEL=INFO

# Morning Routine (uncomment and fill in to enable)
# OPENWEATHER_API_KEY=your-openweathermap-api-key
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# HOME_ADDRESS=123 Main St, Indianapolis, IN
# WORK_ADDRESS=456 Office Blvd, Indianapolis, IN
# MORNING_ROUTINE_HOUR=6
# MORNING_ROUTINE_MINUTE=40
# MORNING_VOLUME=40
# TIMEZONE=America/Indiana/Indianapolis

# Music Discovery (optional — enables recommendations)
# Get a free API key at https://www.last.fm/api/account/create
# LASTFM_API_KEY=your-lastfm-api-key

# Pi-hole DNS ad blocker (optional — enables network stats widget)
# Requires Pi-hole v6 running in Docker, see docker/pihole/setup.sh
# PIHOLE_API_URL=http://localhost:8080
# PIHOLE_API_KEY=your-pihole-admin-password

# Phase 2 - Game Day (uncomment when ready)
# OPENAI_API_KEY=sk-your-key-here
# ESPN_POLL_INTERVAL=5
# BIG_PLAY_YARD_THRESHOLD=20
# FIELD_GOAL_YARD_THRESHOLD=40

# Fauxmo Alexa integration — set to true to expose 7 virtual switches on the LAN
# that Alexa can discover for voice control ("Alexa, turn on gaming mode").
# FAUXMO_ENABLED=false

# MCP server target — override the Home Hub URL the Claude Code MCP server
# connects to. Defaults to http://localhost:8000. Set this when the production
# Home Hub backend lives on a different machine than the Claude Code dev
# environment (e.g. dedicated dashboard laptop).
# HOME_HUB_URL=http://localhost:8000
